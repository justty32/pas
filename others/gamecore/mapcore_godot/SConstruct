#!/usr/bin/env python
# SConstruct for mapcore_godot GDExtension
# 編譯前需先設定 godot-cpp：
#   git submodule add https://github.com/godotengine/godot-cpp.git godot-cpp
#   git submodule update --init --recursive

import os

env = SConscript("godot-cpp/SConstruct")

env.Append(CPPPATH=[
    "src/",
    "../mapcore_cpp_square/include/",
])

# MSVC: 強制 UTF-8（對應 mapcore_cpp_square/CMakeLists.txt 的 /utf-8）
if env["platform"] == "windows":
    env.Append(CXXFLAGS=["/utf-8"])

# ── mapcore 核心：對應 CMakeLists.txt MAPCORE_SQUARE_SOURCES ─────────────────
mapcore_root = "../mapcore_cpp_square/src/"
mapcore_sources = [
    mapcore_root + "grid.cpp",
    mapcore_root + "terrain.cpp",
    mapcore_root + "map.cpp",
    mapcore_root + "pathfinding.cpp",
    mapcore_root + "rivers.cpp",
    mapcore_root + "features.cpp",
    mapcore_root + "generation/heightmap.cpp",
    mapcore_root + "generation/classify.cpp",
    mapcore_root + "generation/biome.cpp",
    mapcore_root + "generation/postprocess.cpp",
    mapcore_root + "generation/climate.cpp",
    mapcore_root + "generation/depressions.cpp",
    mapcore_root + "generation/pipeline.cpp",
]

# ── GDExtension 橋接層 ────────────────────────────────────────────────────────
extension_sources = Glob("src/*.cpp")

# ── 輸出路徑：demo/bin/libmapcore_godot.<platform>.<target>.<arch>.<ext> ────
library = env.SharedLibrary(
    "demo/bin/libmapcore_godot{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
    source=extension_sources + mapcore_sources,
)
Default(library)
