[gd_resource type="AnimationNodeStateMachine" format=3]

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_525of"]
animation = &"idle"

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_28ogq"]
animation = &"punch"

[sub_resource type="AnimationNodeStateMachineTransition" id="AnimationNodeStateMachineTransition_53dfo"]

[sub_resource type="AnimationNodeStateMachineTransition" id="AnimationNodeStateMachineTransition_v78c7"]
xfade_time = 0.2
switch_mode = 1
advance_mode = 2
advance_condition = &"do_punch"

[sub_resource type="AnimationNodeStateMachineTransition" id="AnimationNodeStateMachineTransition_v87u7"]
xfade_time = 0.15
break_loop_at_end = true
switch_mode = 2
advance_mode = 2

[resource]
states/idle/node = SubResource("AnimationNodeAnimation_525of")
states/idle/position = Vector2(200, 160)
states/punch/node = SubResource("AnimationNodeAnimation_28ogq")
states/punch/position = Vector2(460, 160)
transitions = ["Start", "idle", SubResource("AnimationNodeStateMachineTransition_53dfo"), "idle", "punch", SubResource("AnimationNodeStateMachineTransition_v78c7"), "punch", "idle", SubResource("AnimationNodeStateMachineTransition_v87u7")]
