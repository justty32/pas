[gd_resource type="AnimationNodeStateMachine" format=3 uid="uid://b8sm0fighter"]

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_idle"]
animation = &"idle"

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_punch"]
animation = &"punch"

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_Start_idle"]

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_idle_punch"]
xfade_time = 0.2
switch_mode = 1
advance_mode = 2
advance_condition = &"do_punch"

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_punch_idle"]
xfade_time = 0.15
switch_mode = 2
advance_mode = 2
break_loop_at_end = true

[resource]
states/idle/node = SubResource("AnimationNodeAnimation_idle")
states/idle/position = Vector2(200, 160)
states/punch/node = SubResource("AnimationNodeAnimation_punch")
states/punch/position = Vector2(460, 160)
transitions = ["Start", "idle", SubResource("Transition_Start_idle"), "idle", "punch", SubResource("Transition_idle_punch"), "punch", "idle", SubResource("Transition_punch_idle")]
graph_offset = Vector2(0, 0)
