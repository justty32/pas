[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_guard_punch"]

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_step_in_punch"]

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_idle_guard"]

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_idle_step_in"]

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_Start_idle"]

[resource]
states/Start/node = SubResource("AnimationNodeStartState_start")
