# 忽略克隆的專案原始碼，僅託管分析結果
projects/*
!projects/.gitkeep

# 忽略 Agent 的臨時檔案
**/gemini_temp/*
!**/gemini_temp/session_resume.md

# 系統檔案
.DS_Store
Thumbs.db
node_modules/
dist/
build/
**/build*/
project_analysis

.venv
__pycache__/
*.pyc
.ipynb_checkpoints/

# .NET/MSBuild 建置快取（NuGet 暫存）
**/obj/
**/bin/

# SCons (GDExtension 建置產物)
.sconsign.dblite
**/.scons_temp/

# Godot 編輯器快取（不應提交）
**/.godot/

# GDExtension 編譯產出二進制
others/gamecore/mapcore_godot/demo/bin/*.dll
others/gamecore/mapcore_godot/demo/bin/*.so
others/gamecore/mapcore_godot/demo/bin/*.dylib
others/gamecore/mapcore_godot/demo/bin/*.framework
